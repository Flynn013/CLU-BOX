<!--
  CLU/BOX splash-screen animated icon.

  Renders "CLU/BOX" in a minimal 7-segment terminal style using neon-green
  (#39FF14) vector paths on a transparent background (the window background is
  already pure black via windowSplashScreenBackground in themes.xml).

  Animation sequence (total ≈ 1 200 ms):
    0 – 700 ms  : boot-up scale-in  (group 0.8 → 1.0, decelerate)
    0 – 500 ms  : fade-in           (fillAlpha 0.0 → 1.0)
    500 – 850 ms: neon pulse dim    (fillAlpha 1.0 → 0.45)
    850 –1200 ms: neon pulse bright (fillAlpha 0.45 → 1.0)
-->

<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

  <!-- ── Static drawable ───────────────────────────────────────────────── -->
  <aapt:attr name="android:drawable">
    <vector
        android:width="432dp"
        android:height="432dp"
        android:viewportWidth="432"
        android:viewportHeight="432">

      <!--
        All seven glyphs (C L U / B O X) share one compound <path> so that
        a single fillAlpha animator drives the neon-green pulse uniformly.

        Letter grid: 36 × 60 px per character, 10 px gap, centred in 432×432.
        Vertical centre: y = 186  (= (432 - 60) / 2)
        Horizontal start: x = 68  (= (432 - 296) / 2,  296 = full run width)

        Glyph positions (x baseline):
          C=68  L=114  U=160  /=206  B=236  O=282  X=328
      -->
      <group
          android:name="logo_group"
          android:pivotX="216"
          android:pivotY="216"
          android:scaleX="0.8"
          android:scaleY="0.8">

        <path
            android:name="logo_text"
            android:fillColor="#FF39FF14"
            android:fillAlpha="0"
            android:pathData="
              M70,186 h32 v6 h-32 Z
              M68,192 h6 v22 h-6 Z
              M68,218 h6 v22 h-6 Z
              M70,240 h32 v6 h-32 Z

              M114,186 h6 v54 h-6 Z
              M114,240 h36 v6 h-36 Z

              M160,186 h6 v54 h-6 Z
              M190,186 h6 v54 h-6 Z
              M160,240 h36 v6 h-36 Z

              M220,186 L226,186 L212,246 L206,246 Z

              M236,186 h6 v54 h-6 Z
              M242,186 h22 v6 h-22 Z
              M264,192 h5 v22 h-5 Z
              M242,214 h22 v6 h-22 Z
              M264,220 h5 v20 h-5 Z
              M242,240 h22 v6 h-22 Z

              M284,186 h28 v6 h-28 Z
              M282,192 h6 v52 h-6 Z
              M312,192 h6 v52 h-6 Z
              M284,240 h28 v6 h-28 Z

              M328,186 L336,186 L364,246 L356,246 Z
              M356,186 L364,186 L336,246 L328,246 Z"/>

      </group>
    </vector>
  </aapt:attr>

  <!-- ── Animators ─────────────────────────────────────────────────────── -->

  <!-- Scale-in the whole group from 80 % to 100 % -->
  <target android:name="logo_group">
    <aapt:attr name="android:animation">
      <set xmlns:android="http://schemas.android.com/apk/res/android"
          android:ordering="together">
        <objectAnimator
            android:propertyName="scaleX"
            android:duration="700"
            android:valueFrom="0.8"
            android:valueTo="1.0"
            android:interpolator="@android:interpolator/decelerate_quad"/>
        <objectAnimator
            android:propertyName="scaleY"
            android:duration="700"
            android:valueFrom="0.8"
            android:valueTo="1.0"
            android:interpolator="@android:interpolator/decelerate_quad"/>
      </set>
    </aapt:attr>
  </target>

  <!-- Fade-in then neon-green pulse on the text path -->
  <target android:name="logo_text">
    <aapt:attr name="android:animation">
      <set xmlns:android="http://schemas.android.com/apk/res/android"
          android:ordering="sequentially">
        <!-- 0 – 500 ms : fade in -->
        <objectAnimator
            android:propertyName="fillAlpha"
            android:duration="500"
            android:valueFrom="0.0"
            android:valueTo="1.0"/>
        <!-- 500 – 850 ms : pulse dim -->
        <objectAnimator
            android:propertyName="fillAlpha"
            android:duration="350"
            android:valueFrom="1.0"
            android:valueTo="0.45"/>
        <!-- 850 – 1200 ms : pulse bright -->
        <objectAnimator
            android:propertyName="fillAlpha"
            android:duration="350"
            android:valueFrom="0.45"
            android:valueTo="1.0"/>
      </set>
    </aapt:attr>
  </target>

</animated-vector>
